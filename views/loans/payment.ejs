<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Payment - MySecureLoans</title>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <style>
    body {margin:0;font-family:Arial;background:#f5f7fa;}
    .container {background:white;margin:50px auto;padding:40px;width:500px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);}
    h1 {color:#0A3D62;}
    .details {margin:20px 0;padding:15px;background:#f8f9fa;border-radius:4px;}
    .btn {background:#1abc9c;color:white;padding:12px 25px;border:none;cursor:pointer;border-radius:4px;width:100%;margin-top:15px;font-size:16px;}
    .btn:hover {background:#16a085;}
  </style>
</head>
<body>
  <div class="container">
    <h1>Complete Your Payment</h1>
    
    <div class="details">
      <p><strong>Loan Type:</strong> <%= loanType %></p>
      <p><strong>Amount:</strong> ₹<%= amount %></p>
      <p><strong>Application ID:</strong> <%= applicationId %></p>
    </div>
    
    <button class="btn" onclick="initiatePayment()">Pay Now with Razorpay</button>
    
    <a href="/" style="display:block;text-align:center;margin-top:20px;color:#0A3D62;">Back to Home</a>
  </div>

  <script>
    function initiatePayment() {
      const options = {
        key: '<%= razorpayKey %>',
        amount: <%= amount * 100 %>,
        currency: "INR",
        name: "MySecureLoans",
        description: "<%= loanType %>",
        order_id: "<%= orderId %>",
        handler: function(response) {
          fetch('/loans/verify-payment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              razorpay_order_id: response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature: response.razorpay_signature,
              loanId: '<%= loanId %>'
            })
          }).then(res => res.json())
            .then(data => {
              if (data.success) {
                alert('Payment successful!');
                window.location.href = '/';
              } else {
                alert('Payment verification failed');
              }
            });
        }
      };
      const rzp = new Razorpay(options);
      rzp.open();
    }
  </script>
</body>
</html>
