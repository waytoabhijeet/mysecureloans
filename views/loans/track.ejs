<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Track Your Loan</title>
  <style>
    body {margin:0;font-family:Arial;background:#f5f7fa;}
    .container {background:white;margin:50px auto;padding:40px;width:500px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);}
    h1 {color:#0A3D62;}
    .status-badge {display:inline-block;padding:8px 15px;border-radius:20px;font-weight:bold;margin:10px 0;}
    .status-applied {background:#ffc107;color:black;}
    .status-review {background:#17a2b8;color:white;}
    .status-approved {background:#28a745;color:white;}
    .status-rejected {background:#dc3545;color:white;}
    .status-completed {background:#6c757d;color:white;}
    .details {margin:20px 0;padding:15px;background:#f8f9fa;border-radius:4px;}
    .btn {background:#0A3D62;color:white;padding:12px 25px;border:none;text-decoration:none;display:inline-block;margin-top:20px;border-radius:4px;cursor:pointer;}
  </style>
</head>
<body>
  <div class="container">
    <h1>Loan Application Status</h1>
    <p><strong>Application ID:</strong> <%= loan.applicationId %></p>
    
    <div class="status-badge status-<%= loan.status.toLowerCase().replace(' ', '-') %>">
      <%= loan.status %>
    </div>
    
    <div class="details">
      <p><strong>Name:</strong> <%= loan.name %></p>
      <p><strong>Loan Type:</strong> <%= loan.loanType %></p>
      <p><strong>Amount:</strong> ₹<%= loan.amount %></p>
      <p><strong>Applied On:</strong> <%= new Date(loan.appliedAt).toLocaleDateString() %></p>
      <% if (loan.approvalDate) { %>
        <p><strong>Updated On:</strong> <%= new Date(loan.approvalDate).toLocaleDateString() %></p>
      <% } %>
    </div>
    
    <a href="/" class="btn">Back to Home</a>
  </div>
</body>
</html>
